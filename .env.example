# Herald backend URL
NEXT_PUBLIC_HERALD_API_URL=http://localhost:8000

# Formspree form ID — sign up at https://formspree.io to get yours
NEXT_PUBLIC_FORMSPREE_ID=your_form_id_here

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Google — https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub — https://github.com/settings/developers → OAuth Apps
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Cloudflare R2 — Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=herald-data-main

